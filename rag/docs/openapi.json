            "title": "Doc Id"
          },
          "filename": {
            "type": "string",
            "title": "Filename"
          },
          "source": {
            "type": "string",
            "title": "Source"
          },
          "num_chunks": {
            "type": "integer",
            "title": "Num Chunks"
          },
          "chunk_ids": {
            "items": {
              "type": "integer"
            },
            "type": "array",
            "title": "Chunk Ids"
          },
          "created_at": {
            "type": "string",
            "title": "Created At"
          }
        },
        "type": "object",
        "required": [
          "doc_id",
          "filename",
          "source",
          "num_chunks",
          "chunk_ids",
          "created_at"
        ],
        "title": "DocumentUploadResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "stats": {
            "additionalProperties": true,
            "type": "object",
            "title": "Stats"
          }
        },
        "type": "object",
        "required": [
          "status",
          "stats"
        ],
        "title": "HealthResponse"
      },
      "IngestBlocksRequest": {
        "properties": {
          "blocks": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Blocks",
            "description": "文档块列表（process/ 输出的 JSON 数组）"
          },
          "filename": {
            "type": "string",
            "title": "Filename",
            "description": "来源标识（如文件名/页面名）",
            "default": "manual"
          }
        },
        "type": "object",
        "required": [
          "blocks"
        ],
        "title": "IngestBlocksRequest"
      },
      "RetrieveRequest": {
        "properties": {
          "query": {
            "type": "string",
            "minLength": 1,
            "title": "Query",
            "description": "用户查询",
            "examples": [
              "广告限流后怎么办"
            ]
          },
          "dialogue": {
            "anyOf": [
              {
                "items": {
                  "$ref": "#/components/schemas/DialogueTurn"
