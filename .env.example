# ============================================================================
# CustomerServiceAgent 环境变量配置模板
# ============================================================================
# 使用方法：
#   1. 复制本文件为 .env：  cp .env.example .env
#   2. 编辑 .env 填写实际值（敏感信息务必替换为你自己的密钥，不要提交到仓库）
#   3. config/config_loader.py、process/utils/config.py、rag/config.py 会自动
#      加载 .env（依赖 python-dotenv），配置优先级：
#      环境变量 > .env 文件 > config/config.json > 代码默认值
#   4. .env 已被 .gitignore 忽略，不会提交到仓库；.env.example 是模板，必须入库
#
# 分层结构说明（与代码模块对应）：
#   §1 敏感信息         —— API Key / 密码类，任何环境都不应硬编码或入库
#   §2 运行环境选择      —— dev / prod 切换开关，决定 §5/§6 使用哪一组 *_DEV / *_PROD 值
#   §3 process/ 专属配置 —— 仅 process/utils/config.py 读取，HTML 清洗分块与摘要生成用
#   §4 model/ 与 rag/ 共用 —— TEI 推理服务地址（Embedding + Reranker）
#   §5 rag/ 专属配置     —— rag/config.py 读取，检索/融合/精排/生成/上传全部参数
#   §6 Milvus / Elasticsearch —— rag/ 生产后端数据库连接（本地降级模式下可不填）
#   §7 agent/ 核心配置   —— hello_agents 框架读取（更多可选项见 agent/.env.example）
# ============================================================================


# ============================================================================
# §1 敏感信息（API 密钥 / 密码，切勿提交到仓库）
# ============================================================================

# DeepSeek API Key，用于 model/utils/build_dataset.py 生成 Reranker 训练数据
# 获取方式：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# DeepSeek API 基础地址（一般无需修改）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Milvus / Elasticsearch 认证（无认证部署可留空，见 §6）
MILVUS_USER=
MILVUS_PASSWORD=
ES_USER=
ES_PASSWORD=


# ============================================================================
# §2 运行环境选择（dev / prod）
# ============================================================================
# 决定 rag/config.py 读取 §6 中 _DEV 还是 _PROD 后缀的变量（Milvus/ES 主机、
# collection/index 名称）。可选值：dev（默认，本地开发） / prod（生产部署）。
RAG_ENV=dev

# 日志级别。可选值：DEBUG / INFO / WARNING / ERROR，生产环境建议 INFO 或 WARNING
LOG_LEVEL=INFO

# 语言。可选值：zh（中文）/ en（英文），影响部分分词与摘要 Prompt 语言
LANG=zh


# ============================================================================
# §3 process/ 专属配置（HTML 清洗、分块、摘要生成）
# ============================================================================

# --- LLM 摘要/问题生成/Query 重写服务 ---
# vLLM Chat 接口地址（OpenAI 兼容协议）
VLLM_API_URL=http://localhost:8011/v1/chat/completions
# vLLM Embedding 接口地址（用于 html_pruner.py 的 embedding 粗剪枝）
VLLM_EMBED_API_URL=http://localhost:8010/v1/embeddings
# vLLM 请求超时时间（秒）
VLLM_TIMEOUT=60
# vLLM 最大并发请求数（配合 asyncio.Semaphore 限流，避免打爆推理服务）
VLLM_MAX_CONCURRENT_REQUESTS=32
# vLLM 批量摘要生成的批大小
VLLM_BATCH_SIZE=32

# Ollama Chat 接口地址（可选，用于 rewrite_query_ollama_async 的备选 Query 重写路径）
OLLAMA_API_URL=http://localhost:11434/v1/chat/completions

# --- 模型名称（用于摘要生成 Prompt 中标注 / 日志展示，非实际推理服务地址） ---
EMBED_MODEL=Qwen/Qwen3-Embedding-4B
RERANK_MODEL=Qwen/Qwen3-Reranker-4B
LLM_MODEL=THUDM/glm-4-9b-chat
# 推理设备。可选值：cuda:0（GPU）/ cpu
DEVICE=cuda:0

# --- 文档分块参数（process/ Block Tree 分块，中文按字符计数） ---
# 单块最大词数（超过则继续下钻拆分）
MAX_NODE_WORDS_EMBED=4096
# 单块最小词数（低于则尝试与邻近节点合并）
MIN_NODE_WORDS_EMBED=48


# ============================================================================
# §4 model/ 与 rag/ 共用：TEI 推理服务地址
# ============================================================================
# TEI (Text Embeddings Inference) 服务地址，由 model/inference/docker-compose-tei.yml
# 一键部署；rag/ 的 embed_backend=tei / rerank_backend=tei 时会调用这两个地址。
# 未部署时 rag/ 自动降级为本地实现（哈希嵌入 / 余弦代理），不影响服务启动。
TEI_EMBED_URL=http://localhost:8080
TEI_RERANK_URL=http://localhost:8081


# ============================================================================
# §5 rag/ 专属配置（检索 / 融合 / 精排 / 生成 / 上传，详见 rag/config.py）
# ============================================================================

# --- 各组件后端选择：local（本地降级，默认，零外部依赖开箱即用）或对应生产后端 ---
# 向量库后端。可选值：local / milvus
RAG_VECTOR_BACKEND=local
# 关键词库后端。可选值：local / es
RAG_KEYWORD_BACKEND=local
# Embedding 后端。可选值：local（哈希嵌入） / tei（真实 Qwen3-Embedding，见 §4）
RAG_EMBED_BACKEND=local
# Reranker 后端。可选值：local（余弦代理） / tei（真实 Qwen3-Reranker，见 §4）
RAG_RERANK_BACKEND=local
# 生成后端。可选值：local（抽取式摘录兜底） / vllm（真实 LLM 生成，复用 §3 VLLM_API_URL）
RAG_GENERATION_BACKEND=local

# --- 检索参数 ---
# 单路（向量/关键词）召回条数
RAG_TOP_K_RECALL=20
# 精排后最终返回条数
RAG_TOP_K_FINAL=5

# --- 融合参数 ---
# 融合策略。可选值：rrf（Reciprocal Rank Fusion，默认，无需归一化更鲁棒） / weighted（加权求和）
RAG_FUSION_METHOD=rrf
# RRF 平滑常数（method=rrf 时生效，值越大排名差异的影响越平滑）
RAG_FUSION_RRF_K=60
# 加权融合时，向量检索 / 关键词检索各自的权重（method=weighted 时生效，建议之和为 1）
RAG_FUSION_WEIGHT_MILVUS=0.5
RAG_FUSION_WEIGHT_ES=0.5

# --- 去重参数（复用 process/ 的 TF-IDF + cosine 去重算法） ---
# 正文相似度阈值，超过视为重复块（0~1，越大越严格）
RAG_DEDUP_THRESHOLD_CONTENT=0.9
# 页面名相似度阈值（0~1）
RAG_DEDUP_THRESHOLD_PAGE_NAME=0.6

# --- 通用文本分块参数（rag/indexing/chunker.py，独立于 process/ 的 Block Tree 分块，
#      用于用户直接上传的 .txt/.md/.pdf 等纯文本文档） ---
# 单块最大字符数
RAG_CHUNK_SIZE=500
# 相邻块重叠字符数（保留跨块语义连续性）
RAG_CHUNK_OVERLAP=50

# --- 生成参数 ---
# 送入 LLM 的检索上下文最大字符数（超长时截断，优先保留排序靠前的高相关上下文）
RAG_GEN_MAX_CONTEXT_CHARS=3000
# LLM 生成的最大 token 数
RAG_GEN_MAX_NEW_TOKENS=512
# 无生成模型服务时，抽取式兜底回答中单条上下文摘录片段的最大字符数
RAG_GEN_SNIPPET_MAX_CHARS=200

# --- 精排参数 ---
# Reranker 输入文档（title+summary+text 拼接）截断长度，避免超出模型 max_length
RAG_RERANK_DOC_MAX_CHARS=2000

# --- 上传与写入限制 ---
# 单个文档上传的最大体积（MB）
RAG_UPLOAD_MAX_SIZE_MB=20
# 单次 /api/documents/ingest_blocks 接口允许导入的最大知识块数量，防止超大 payload
RAG_MAX_BLOCKS_PER_INGEST=5000

# --- 流式问答参数 ---
# /api/chat/stream 接口逐段推送答案文本时，每个 SSE data chunk 的字符数
RAG_STREAM_ANSWER_CHUNK_CHARS=20

# --- 数据目录 ---
# 本地降级后端（LocalVectorStore/LocalKeywordStore/DocRegistry）持久化数据的存储目录
# 默认 rag/data/，无需修改；仅在需要自定义存储位置时填写
RAG_DATA_DIR=


# ============================================================================
# §6 Milvus 向量数据库 / Elasticsearch 搜索引擎（rag/ 生产后端）
# ============================================================================
# 仅当 RAG_VECTOR_BACKEND=milvus / RAG_KEYWORD_BACKEND=es 时生效；
# 本地降级模式（默认）下可全部留空，不影响服务启动。

# --- Milvus（dev / prod 按 §2 RAG_ENV 二选一生效） ---
MILVUS_HOST_DEV=127.0.0.1
MILVUS_HOST_PROD=127.0.0.1
# Milvus 端口（dev/prod 共用）
MILVUS_PORT=19530
MILVUS_COLLECTION_DEV=htmlrag_dev
MILVUS_COLLECTION_PROD=htmlrag_prod

# --- Elasticsearch（dev / prod 按 §2 RAG_ENV 二选一生效） ---
ES_HOST_DEV=127.0.0.1
ES_HOST_PROD=127.0.0.1
# ES 端口（dev/prod 共用）
ES_PORT=9200
ES_INDEX_DEV=htmlrag_dev
ES_INDEX_PROD=htmlrag_prod


# ============================================================================
# §7 agent/ 核心配置（hello_agents 框架）
# ============================================================================
# hello_agents（agent/hello_agents/core/llm.py）通过以下 4 个通用环境变量自动检测
# LLM Provider（OpenAI 兼容 / Anthropic / Gemini），运行 `agent/tests/`、
# `scripts/run_AGTserver.sh` 前必须正确配置，否则会抛出
# "必须提供模型名称" / "LLM_API_KEY 未配置" 异常。
#
# 更多可选配置（Tavily/SerpApi 搜索、Qdrant 向量库、Neo4j 图数据库、
# GitHub/HuggingFace Token 等 Skills 相关变量）见 agent/.env.example，
# 如需使用对应 Skill 请参考该文件单独配置。

# 模型名称（如 gpt-4o-mini / deepseek-chat / glm-4-flash 等，需与 LLM_BASE_URL 服务匹配）
LLM_MODEL_ID=your-model-name

# API 密钥
LLM_API_KEY=your-api-key-here

# 服务地址（OpenAI 兼容协议的 base_url，如 https://api.deepseek.com/v1）
LLM_BASE_URL=your-api-base-url

# 请求超时时间（秒），可选，默认 60
LLM_TIMEOUT=60
