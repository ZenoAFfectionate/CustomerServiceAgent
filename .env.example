# ========================
# HtmlRAG 环境变量配置
# ========================
# 使用方法：
#   1. 复制本文件为 .env:  cp .env.example .env
#   2. 编辑 .env 填写实际值
#   3. config.py 会自动加载 .env（依赖 python-dotenv）
#   4. .env 已被 .gitignore 忽略，不会提交到仓库

# ========================
# API 密钥（敏感信息）
# ========================
# DeepSeek API Key，用于 finetune/build_dataset.py 生成训练数据
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ========================
# vLLM 推理服务
# ========================
# vLLM Chat 接口地址（摘要生成 / Query 重写）
VLLM_API_URL=http://localhost:8011/v1/chat/completions

# vLLM Embedding 接口地址
VLLM_EMBED_API_URL=http://localhost:8010/v1/embeddings

# vLLM 请求超时（秒）
VLLM_TIMEOUT=60

# vLLM 最大并发请求数
VLLM_MAX_CONCURRENT_REQUESTS=32

# vLLM 批量摘要大小
VLLM_BATCH_SIZE=32

# ========================
# Ollama 服务（可选）
# ========================
# Ollama Chat 接口地址，用于 rewrite_query_ollama_async
OLLAMA_API_URL=http://localhost:11434/v1/chat/completions

# ========================
# DeepSeek 服务
# ========================
# DeepSeek API 基础地址
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ========================
# 文件下载服务（黑洞服务）
# ========================
# 用于 API 接口下载 HTML 文件的内部服务地址
BLACKHOLE_URL=192.168.18.66:28082

# ========================
# Milvus 向量数据库
# ========================
# dev 环境
MILVUS_HOST_DEV=127.0.0.1
MILVUS_PORT=19530
MILVUS_COLLECTION_DEV=htmlrag_dev

# prod 环境
MILVUS_HOST_PROD=127.0.0.1
MILVUS_COLLECTION_PROD=htmlrag_prod

# Milvus 认证（可选，无认证则留空）
MILVUS_USER=
MILVUS_PASSWORD=

# ========================
# Elasticsearch 搜索引擎
# ========================
# dev 环境
ES_HOST_DEV=127.0.0.1
ES_PORT=9200
ES_INDEX_DEV=htmlrag_dev

# prod 环境
ES_HOST_PROD=127.0.0.1
ES_INDEX_PROD=htmlrag_prod

# ES 认证（可选，无认证则留空）
ES_USER=
ES_PASSWORD=

# ========================
# 模型配置
# ========================
# 嵌入模型名称或路径
EMBED_MODEL=bce-embedding-base_v1

# Reranker 模型名称或路径
RERANK_MODEL=bce-reranker-base_v1

# 摘要 / 重写 LLM 模型
LLM_MODEL=THUDM/glm-4-9b-chat

# 推理设备
DEVICE=cuda:0

# ========================
# 文档分块参数
# ========================
MAX_NODE_WORDS_EMBED=4096
MIN_NODE_WORDS_EMBED=48

# ========================
# 运行环境
# ========================
# 默认环境（dev / prod）
RAG_ENV=dev

# 日志级别
LOG_LEVEL=INFO

# 语言（zh / en）
LANG=zh
